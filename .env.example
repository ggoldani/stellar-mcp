# Runtime transport: stdio | http-sse
MCP_TRANSPORT=stdio

# Stellar network: mainnet | testnet
STELLAR_NETWORK=testnet

# Optional endpoint overrides (must be https and allowlisted)
# STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
# STELLAR_RPC_URL=https://soroban-testnet.stellar.org
# STELLAR_SEP38_URL=https://anchor.example.com/price

# Optional allowlists (comma-separated hosts/domains)
# STELLAR_ALLOWED_HOSTS=horizon-testnet.stellar.org,soroban-testnet.stellar.org,anchor.example.com
# STELLAR_TRUSTED_ANCHOR_DOMAINS=anchor.example.com

# Secret key for signing (never commit real secrets)
# STELLAR_SECRET_KEY=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Auto-sign policy: safe | guarded | expert
STELLAR_AUTO_SIGN_POLICY=safe

# Legacy compatibility flags (used if policy is unset)
STELLAR_AUTO_SIGN=false
STELLAR_AUTO_SIGN_LIMIT=0

# Default USDC issuer used for valuation logic
STELLAR_USDC_ISSUER=GA5ZSEJYB37JRC5AVCIA5MOP4RHTM335X2KGX3IHOJAPP5RE34K4KZVN

# HTTP/SSE transport settings
PORT=3000
STELLAR_REQUEST_TIMEOUT_MS=30000
MCP_HTTP_RATE_LIMIT_PER_MIN=60
MCP_HTTP_MAX_CONCURRENT=20
MCP_HTTP_MAX_PAYLOAD_BYTES=262144
MCP_HTTP_TRUST_PROXY=false

# Historical meta tools (Phase B): disk cache + XDR bounds
# STELLAR_META_CACHE_ENABLED=true
# STELLAR_META_CACHE_TTL_MS=300000
# STELLAR_META_CACHE_DIR=
# STELLAR_META_MAX_XDR_CHARS=8192
